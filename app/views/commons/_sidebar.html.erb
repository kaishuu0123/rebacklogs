<%
  sprints_props = project.sprints.opening.map do |sprint|
    {
      id: sprint.id,
      title: sprint.title,
      kanbanPath: project_sprint_kanban_path(project, sprint)
    }
  end

  project_props = {
    id: project.id,
    title: project.title,
    imageUrl: project.project_image_url,
    projectPath: project_path(project),
    closedSprintsPath: closed_sprints_project_path(project),
    settingsPath: settings_project_path(project)
  }
%>
<%= turbo_mount "ProjectSidebar", props: {
  project: project_props,
  sprints: sprints_props,
  currentPath: request.path
} %>
