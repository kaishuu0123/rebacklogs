<%
  current_user_props = if current_user.present?
    {
      username: current_user.username,
      imageUrl: current_user.user_image_url,
      isAdmin: current_user.has_role?(:admin),
      settingsPath: application_settings_path,
      profilePath: profiles_path,
      signOutPath: destroy_user_session_path
    }
  end
%>
<%= turbo_mount "Header", props: {
  currentUser: current_user_props,
  signInPath: new_user_session_path,
  rootPath: root_path,
  demoMode: ENV['DEMO_MODE'] == 'true',
  hideSignIn: controller_name == 'sessions'
} %>
