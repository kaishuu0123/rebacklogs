<% if page.current? %>
  <li>
    <%= content_tag :a, page, data: { remote: remote }, rel: page.rel,
          class: 'inline-flex items-center justify-center w-8 h-8 text-sm rounded-md bg-primary text-primary-foreground font-medium' %>
  </li>
<% else %>
  <li>
    <%= link_to page, url, remote: remote, rel: page.rel,
          class: 'inline-flex items-center justify-center w-8 h-8 text-sm rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground' %>
  </li>
<% end %>
