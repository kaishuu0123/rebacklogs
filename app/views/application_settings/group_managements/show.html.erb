<div class="flex min-h-[calc(100vh-3.5rem)]">
  <%= render 'application_settings/common/sidebar' %>

  <div class="flex-1 p-6 space-y-6">
    <h1 class="text-2xl font-bold"><%= t('.title', default: 'Group Managements') %>: <%= @group.name %></h1>

    <div class="grid grid-cols-2 gap-6">
      <div class="rounded-xl border bg-card shadow-sm">
        <div class="border-b px-4 py-3">
          <h2 class="text-sm font-semibold"><%= t('.add_users_to_group', default: 'Add user(s) to the group') %></h2>
        </div>
        <div class="p-4">
          <%= form_with model: @group, url: application_settings_group_managements_add_user_path(@group), local: true do |f| %>
            <div class="space-y-3">
              <select name="group[user_id]"
                      class="h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                <option value=""><%= t('.select_user', default: 'Select User...') %></option>
                <% @addable_users.each do |user| %>
                  <option value="<%= user.id %>"><%= user.username %></option>
                <% end %>
              </select>
              <div class="flex justify-end">
                <%= f.submit t('.add_user', default: 'Add User'),
                      class: 'h-9 cursor-pointer rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90' %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-xl border bg-card shadow-sm">
        <div class="border-b px-4 py-3">
          <h2 class="text-sm font-semibold"><%= t('.users', default: 'Users') %></h2>
        </div>
        <ul class="divide-y">
          <% @group.users.each do |user| %>
            <li class="flex items-center gap-3 px-4 py-3">
              <img src="<%= user.user_image_url %>" width="32" height="32" class="rounded shrink-0" />
              <div class="flex-1 min-w-0 text-sm"><%= user.username %></div>
              <%= link_to application_settings_group_managements_remove_user_path(@group, user),
                    data: { turbo_method: :delete },
                    class: 'text-destructive hover:text-destructive/80 text-sm' do %>
                <i data-lucide="trash-2" class="size-4"></i>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
