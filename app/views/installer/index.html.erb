<div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
  <div class="w-full max-w-sm space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold">Re:Backlogs Installer</h1>
    </div>

    <div class="rounded-xl border bg-card shadow-sm p-8 space-y-4">
      <% if @installer.errors.present? %>
        <div class="rounded-md bg-destructive/10 px-4 py-3 text-sm text-destructive">
          <ul class="space-y-1">
            <% @installer.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with url: installer_path, local: true, html: { class: 'space-y-4' } do |f| %>
        <div class="space-y-2">
          <label class="text-sm font-medium"><%= t('.username', default: 'Admin username') %></label>
          <%= f.text_field :username,
                value: @installer.username,
                placeholder: 'yourname',
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <label class="text-sm font-medium"><%= t('.email', default: 'Admin email') %></label>
          <%= f.email_field :email,
                value: @installer.email,
                placeholder: 'you@example.com',
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <label class="text-sm font-medium"><%= t('.admin_password', default: 'Admin password') %></label>
          <%= f.password_field :password,
                placeholder: t('activerecord.attributes.user.password', default: 'Password'),
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <label class="text-sm font-medium"><%= t('.admin_password_confirmation', default: "Admin password confirmation") %></label>
          <%= f.password_field :password_confirmation,
                placeholder: t('activerecord.attributes.user.password_confirmation', default: 'Confirm Password'),
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <label class="text-sm font-medium"><%= t('.locale', default: "Locale") %></label>
          <div class="flex gap-6">
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name="locale" value="en" class="h-4 w-4">
              <%= t('.english', default: 'English') %>
            </label>
            <label class="flex items-center gap-2 text-sm">
              <input type="radio" name="locale" value="ja" class="h-4 w-4">
              <%= t('.japanese', default: 'Japanese') %>
            </label>
          </div>
        </div>

        <%= f.submit t('.install', default: 'Install'),
              class: 'h-10 w-full cursor-pointer rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90' %>
      <% end %>
    </div>
  </div>
</div>
