<div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
  <div class="w-full max-w-sm space-y-6">
    <div class="space-y-2 text-center">
      <h1 class="text-2xl font-bold"><%= t('.forgot_your_password', default: 'Forgot your password?') %></h1>
      <p class="text-sm text-muted-foreground"><%= t('.forgot_your_password_message', default: 'Enter the email address used for registration.') %></p>
    </div>

    <div class="rounded-xl border bg-card shadow-sm p-8 space-y-4">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <% if resource.errors.any? %>
          <div class="rounded-md bg-destructive/10 px-4 py-3 text-sm text-destructive">
            <ul class="space-y-1">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-2">
          <%= f.label :email, t('activerecord.attributes.user.email', default: 'Email'), class: 'text-sm font-medium' %>
          <%= f.email_field :email, autofocus: true, placeholder: t('.email_placeholder', default: 'Enter email address'),
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <%= f.submit t('.send_me_reset_password_instructions', default: 'Send reset instructions'),
              class: 'mt-2 h-10 w-full cursor-pointer rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90' %>
      <% end %>
    </div>

    <div class="text-center text-sm text-muted-foreground">
      <%= link_to t('devise.shared.links.sign_in', default: 'Sign In'), new_session_path(resource_name), class: 'hover:text-foreground hover:underline' %>
    </div>
  </div>
</div>
