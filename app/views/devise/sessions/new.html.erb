<div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
  <div class="w-full max-w-sm space-y-6">
    <div class="space-y-2 text-center">
      <h1 class="text-2xl font-bold"><%= t('.sign_in', default: 'Sign in to Re:Backlogs') %></h1>
    </div>

    <div class="rounded-xl border bg-card shadow-sm p-8 space-y-4">
      <% if flash[:alert].present? %>
        <div class="rounded-md bg-destructive/10 px-4 py-3 text-sm text-destructive">
          <%= t('.invalid_credentials', default: 'Username or password is incorrect.') %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'space-y-4', data: { turbo: false } }) do |f| %>
        <div class="space-y-2">
          <%= f.label :login, t('activerecord.attributes.user.login', default: 'Email or Username'), class: 'text-sm font-medium' %>
          <%= f.text_field :login, autofocus: true, placeholder: 'Email or Username',
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <%= f.label :password, t('activerecord.attributes.user.password', default: 'Password'), class: 'text-sm font-medium' %>
          <%= f.password_field :password, autocomplete: 'off', placeholder: '••••••••',
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: 'h-4 w-4 rounded border-input' %>
            <%= f.label :remember_me, class: 'text-sm text-muted-foreground' %>
          </div>
        <% end %>

        <%= f.submit t('.sign_in', default: 'Sign in'),
              class: 'h-10 w-full cursor-pointer rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90' %>
      <% end %>

      <%= render 'devise/shared/omniauth_links' %>
    </div>

    <div class="text-center text-sm text-muted-foreground space-y-1">
      <%= render 'devise/shared/text_links' %>
    </div>
  </div>
</div>
