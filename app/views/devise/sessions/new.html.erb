<div class="flex min-h-[calc(100vh-3.5rem)] items-center justify-center p-4">
  <div class="w-full max-w-sm space-y-6">
    <div class="space-y-2 text-center">
      <h1 class="text-2xl font-bold"><%= t('.sign_in_title', app_name: 'Re:Backlogs', default: 'Sign in to Re:Backlogs') %></h1>
      <% if devise_mapping.registerable? %>
        <p class="text-sm text-muted-foreground">
          <%= t('.no_account', default: "Don't have an account?") %>
          <%= link_to t('devise.shared.links.sign_up', default: 'Sign Up'), new_registration_path(resource_name),
                class: 'underline hover:text-foreground' %>
        </p>
      <% end %>
    </div>

    <div class="rounded-xl border bg-card shadow-sm p-8 space-y-4">
      <% if flash[:alert].present? && flash[:alert] != t('devise.failure.unauthenticated') %>
        <div class="rounded-md bg-destructive/10 px-4 py-3 text-sm text-destructive">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'space-y-4', data: { turbo: false } }) do |f| %>
        <div class="space-y-2">
          <%= f.label :login, t('activerecord.attributes.user.login', default: 'Email or Username'), class: 'text-sm font-medium' %>
          <%= f.text_field :login, autofocus: true, placeholder: t('.login_placeholder', default: 'Enter email or username'),
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <%= f.label :password, t('activerecord.attributes.user.password', default: 'Password'), class: 'text-sm font-medium' %>
            <% if devise_mapping.recoverable? %>
              <%= link_to t('devise.shared.links.forgot_your_password', default: 'Forgot your password?'),
                    new_password_path(resource_name),
                    class: 'text-xs text-muted-foreground hover:text-foreground hover:underline' %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: 'off', placeholder: t('.password_placeholder', default: 'Enter password'),
                class: 'h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: 'h-4 w-4 rounded border-input' %>
            <%= f.label :remember_me, class: 'text-sm text-muted-foreground' %>
          </div>
        <% end %>

        <%= f.submit t('.sign_in', default: 'Sign In'),
              class: 'h-10 w-full cursor-pointer rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90' %>
      <% end %>

      <%= render 'devise/shared/omniauth_links' %>
    </div>

    <%- if devise_mapping.confirmable? %>
      <div class="text-center text-sm text-muted-foreground">
        <%= link_to t('devise.shared.links.didn_t_receive_confirmation_instructions', default: "Didn't receive confirmation instructions?"), new_confirmation_path(resource_name), class: 'block hover:text-foreground hover:underline' %>
      </div>
    <% end %>
    <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) %>
      <div class="text-center text-sm text-muted-foreground">
        <%= link_to t('devise.shared.links.didn_t_receive_unlock_instructions', default: "Didn't receive unlock instructions?"), new_unlock_path(resource_name), class: 'block hover:text-foreground hover:underline' %>
      </div>
    <% end %>
  </div>
</div>
